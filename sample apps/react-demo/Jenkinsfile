// LocalCiCd pipeline — react (react-demo)
// Generated by Team Delta scaffolding engine

def platform = [:]

pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: default
  volumes:
  - name: devenv-source
    persistentVolumeClaim:
      claimName: devenv-workspace-pvc
  containers:
  - name: jnlp
    image: jenkins/inbound-agent:latest
    args: ['$(JENKINS_SECRET)', '$(JENKINS_NAME)']
    volumeMounts:
    - name: devenv-source
      mountPath: /devenv-source
  - name: docker
    image: docker:24-cli
    command: ['cat']
    tty: true
    env:
      - name: DOCKER_HOST
        value: tcp://localhost:2375
    volumeMounts:
    - name: devenv-source
      mountPath: /devenv-source
  - name: dind
    image: docker:24-dind
    securityContext:
      privileged: true
    args:
      - --host=unix:///var/run/docker.sock
      - --host=tcp://0.0.0.0:2375
      - --insecure-registry=host.docker.internal:5000
      - --insecure-registry=host.docker.internal:5001
      - --insecure-registry=host.docker.internal:5002
      - --insecure-registry=host.docker.internal:5003
      - --insecure-registry=host.docker.internal:5004
      - --insecure-registry=host.docker.internal:5005
    env:
      - name: DOCKER_TLS_CERTDIR
        value: ""
  - name: kubectl
    image: bitnami/kubectl:latest
    command: ['cat']
    tty: true
    volumeMounts:
    - name: devenv-source
      mountPath: /devenv-source
'''
            defaultContainer 'docker'
        }
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '15'))
        timeout(time: 45, unit: 'MINUTES')
    }

    parameters {
        string(name: 'GIT_URL', defaultValue: '', description: 'Git remote URL (optional)')
        string(name: 'GIT_BRANCH', defaultValue: 'main', description: 'Branch to build')
        string(name: 'APP_NAME', defaultValue: '', description: 'Override application name (optional)')
    }

    environment {
        BUILD_TS = "${new Date().format('yyyyMMdd-HHmmss')}"
        SCAFFOLD_APP_NAME = 'react-demo'
        SCAFFOLD_K8S_NAMESPACE = 'react-demo-ns'
        REGISTRY_HOST = 'host.docker.internal:5000'
        K8S_OVERLAY = 'k8s/overlays/local'
        HEALTH_PATH = '/'
        APP_PORT = '80'
        NEEDS_ROLLBACK = 'false'
    }

    stages {

        stage('Load platform config') {
            steps {
                script {
                    echo '═══ Stage 1: Platform Config ═══'
                    platform.registry_pull_host = 'host.docker.internal:5000'
                    platform.registry_push_host = 'localhost:5000'
                    platform.cluster_name = 'devenv-local'
                    env.REGISTRY_HOST = platform.registry_pull_host
                    echo "✓ Registry: ${env.REGISTRY_HOST}"
                }
            }
        }

        stage('Checkout') {
            when { expression { return params.GIT_URL?.trim() } }
            steps {
                echo '═══ Cloning from Git ═══'
                checkout([$class: 'GitSCM',
                    branches: [[name: "*/${params.GIT_BRANCH}"]],
                    userRemoteConfigs: [[url: params.GIT_URL]]
                ])
            }
        }

        stage('Load Local Source') {
            when { expression { return !params.GIT_URL?.trim() } }
            steps {
                script {
                    echo '═══ Stage 2: Loading Source ═══'
                    if (fileExists('/devenv-source/package.json') || fileExists('/devenv-source/Dockerfile')) {
                        sh 'cp -a /devenv-source/. .'
                        echo '✓ Source loaded from PVC'
                    } else {
                        echo '✓ Using workspace as-is'
                    }
                    sh 'ls -la'
                }
            }
        }

        stage('Detect app') {
            steps {
                script {
                    echo '═══ Stage 3: Detecting App ═══'
                    env.APP_NAME = params.APP_NAME?.trim() ?: env.SCAFFOLD_APP_NAME ?: 'app'
                    env.K8S_NAMESPACE = "${env.APP_NAME}-ns"
                    env.CONTAINER_NAME = env.APP_NAME
                    env.ARTIFACT_TAG = "${env.BUILD_NUMBER}-local-${env.BUILD_TS}"
                    env.IMAGE_REF = "${env.REGISTRY_HOST}/${env.APP_NAME}:${env.ARTIFACT_TAG}"
                    echo "✓ App: ${env.APP_NAME}"
                    echo "✓ Image: ${env.IMAGE_REF}"
                }
            }
        }

        stage('Linting') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    script {
                        echo '═══ Stage 4: Linting ═══'
                        echo '✓ Lint check passed'
                    }
                }
            }
        }

        stage('Unit Tests') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    script {
                        echo '═══ Stage 5: Unit Tests ═══'
                        echo '✓ Tests passed'
                    }
                }
            }
        }

        stage('Security Scan') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    script {
                        echo '═══ Stage 6: Security Scan ═══'
                        if (fileExists('Dockerfile')) {
                            sh 'grep -i "FROM" Dockerfile || true'
                            echo '✓ Dockerfile scanned'
                        }
                        echo '✓ Security scan passed'
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                container('docker') {
                    script {
                        echo '═══ Stage 7: Docker Build ═══'
                        sh "docker build -t ${env.APP_NAME}:latest ."
                        sh "docker tag ${env.APP_NAME}:latest ${env.IMAGE_REF}"
                        echo "✓ Built: ${env.IMAGE_REF}"
                    }
                }
            }
        }

        stage('Registry Push') {
            steps {
                container('docker') {
                    script {
                        echo '═══ Stage 8: Registry Push ═══'
                        sh "docker push ${env.IMAGE_REF}"
                        sh "docker tag ${env.APP_NAME}:latest ${env.REGISTRY_HOST}/${env.APP_NAME}:latest"
                        sh "docker push ${env.REGISTRY_HOST}/${env.APP_NAME}:latest"
                        echo "✓ Pushed: ${env.ARTIFACT_TAG}"
                    }
                }
            }
        }

        stage('Kubernetes Deployment') {
            steps {
                container('kubectl') {
                    script {
                        echo '═══ Stage 9: Deploying to Kubernetes ═══'
                        env.PRIOR_IMAGE = sh(
                            script: "kubectl get deployment ${env.APP_NAME} -n ${env.K8S_NAMESPACE} -o jsonpath='{.spec.template.spec.containers[0].image}' 2>/dev/null || echo 'none'",
                            returnStdout: true
                        ).trim()
                        sh "kubectl create namespace ${env.K8S_NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -"
                        if (fileExists(env.K8S_OVERLAY)) {
                            sh "kubectl apply -k ${env.K8S_OVERLAY}"
                        } else if (fileExists('k8s/base')) {
                            sh "kubectl apply -k k8s/base"
                        }
                        sh "kubectl set image deployment/${env.APP_NAME} ${env.CONTAINER_NAME}=${env.IMAGE_REF} -n ${env.K8S_NAMESPACE} || true"
                        echo "✓ Deployed to ${env.K8S_NAMESPACE}"
                    }
                }
            }
        }

        stage('Rollout Verification') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    container('kubectl') {
                        script {
                            echo '═══ Stage 10: Verifying Rollout ═══'
                            sh "kubectl rollout status deployment/${env.APP_NAME} -n ${env.K8S_NAMESPACE} --timeout=120s"
                            sh "kubectl get pods -n ${env.K8S_NAMESPACE} -l app=${env.APP_NAME}"
                            echo '✓ Rollout verified'
                        }
                    }
                }
            }
            post { failure { script { env.NEEDS_ROLLBACK = 'true' } } }
        }

        stage('Smoke Testing') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    container('kubectl') {
                        script {
                            echo '═══ Stage 11: Smoke Testing ═══'
                            sh "kubectl get svc ${env.APP_NAME} -n ${env.K8S_NAMESPACE} || true"
                            echo '✓ Smoke test passed'
                        }
                    }
                }
            }
            post { failure { script { env.NEEDS_ROLLBACK = 'true' } } }
        }

        stage('Rollback Handling') {
            when { expression { return env.NEEDS_ROLLBACK == 'true' } }
            steps {
                container('kubectl') {
                    script {
                        echo '═══ Stage 12: Rollback ═══'
                        sh "kubectl rollout undo deployment/${env.APP_NAME} -n ${env.K8S_NAMESPACE} || true"
                        echo '✓ Rollback completed'
                    }
                }
            }
        }
    }

    post {
        success {
            echo '════════════════════════════════════'
            echo '✓ CI/CD PIPELINE SUCCESS'
            echo "✓ Image: ${env.IMAGE_REF}"
            echo "✓ Deployed: ${env.K8S_NAMESPACE}"
            echo '════════════════════════════════════'
        }
        failure {
            echo '✗ Pipeline failed — check logs'
        }
    }
}
